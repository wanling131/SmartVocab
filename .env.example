# SmartVocab 环境变量示例
# 复制为 .env 后按需修改（不要提交真实密码到版本库）

# --- 应用 ---
APP_HOST=0.0.0.0
APP_PORT=5000
# 开发 true；生产务必 false
APP_DEBUG=true
# 生产/预发布：production 或 staging（影响默认调试与错误详情策略）
# APP_ENV=production

# Flask 会话等签名密钥：生产必须设置（建议 openssl rand -hex 32）
# SECRET_KEY=

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 是否在 JSON API 错误中返回异常详情（生产必须为 false）
# EXPOSE_ERROR_DETAILS=false

# CORS：生产请填写前端 Origin，多个用英文逗号分隔，例如 https://app.example.com
# 开发期可使用 *（不推荐上线）
CORS_ORIGINS=*

# 全站 HTTPS 且由反向代理终止 TLS 时可启用 HSTS（仅生产）
# ENABLE_HSTS=1

# 请求体最大体积（MB），防止超大 JSON
# MAX_CONTENT_LENGTH_MB=16

# --- MySQL（与 tools/database.py 一致）---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=smartvocab

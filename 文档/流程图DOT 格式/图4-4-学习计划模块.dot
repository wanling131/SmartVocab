    C1f [label="写入推荐记录表"];
    C1e -> C1e1; C1e -> C1e2; C1e -> C1e3; C1e -> C1e4; C1e -> C1e5; C1e -> C1e6;
    C1e1 [label="采用混合推荐算法"];
